{
  "name": "Growth Ops Copilot",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r requirements.txt && curl -fsSL https://raw.githubusercontent.com/databricks/setup-cli/main/install.sh | sh",
  "forwardPorts": [],
  "remoteEnv": {
    "PYTHONUNBUFFERED": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
